# RUN: ! %sammine --file %full %O 2>&1 | %check %full
# CHECK:          |generic_arg_count.mn:9:20
# CHECK-NEXT:    7|
# CHECK-NEXT:    8|let main() -> i32 {
# CHECK-NEXT:    9|  let x: i32 = pair(42);
# CHECK-NEXT:     |                    ─┬
# CHECK-NEXT:     |                     ╰─ Generic function 'pair' expects 2 arguments, got 1
# CHECK-NEXT:   10|  return 0;
# CHECK-NEXT:   11|}
# CHECK:      # Did something seems wrong? Report it via [https://codeberg.org/badumbatish/sammine-lang/issues]
# CHECK-NEXT: # Give us a screenshot of the error as well as your contextual source code
# CHECK-NEXT: --------------------------------------------------------------------------

let pair<T>(a: T, b: T) -> T {
  return a;
}

let main() -> i32 {
  let x: i32 = pair(42);
  return 0;
}
