# RUN: ! %sammine --file %full %O 2>&1 | %check %full
# CHECK:          |closure_direct_return_tuple_ptr.mn:15:2
# CHECK-NEXT:   13|let make() -> (i32) -> i32 {
# CHECK-NEXT:   14|  let t = (42, true);
# CHECK-NEXT:   15|  return get_fst(&t);
# CHECK-NEXT:     |  ────────────────┬
# CHECK-NEXT:     |                  ╰─ Cannot return partial application of 'get_fst' — it captures a non-linear pointer (may dangle after return)
# CHECK-NEXT:   16|}
# CHECK-NEXT:   17|
# CHECK:      # Did something seems wrong? Report it via [https://codeberg.org/badumbatish/sammine-lang/issues]
# CHECK-NEXT: # Give us a screenshot of the error as well as your contextual source code
# CHECK-NEXT: --------------------------------------------------------------------------

# Test: returning a partial application directly that captures
# a ptr to a stack-allocated tuple.

import std;

let get_fst(p: ptr<(i32, bool)>, dummy: i32) -> i32 {
  let (a, b) = *p;
  return a;
}

let make() -> (i32) -> i32 {
  let t = (42, true);
  return get_fst(&t);
}

let main() -> i32 {
  return 0;
}
