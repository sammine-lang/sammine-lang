// CHECK-NEXT:    4|let main() -> i32 {
// CHECK-NEXT:    5|  let c: char = 'a;
// CHECK-NEXT:     |                ^
// CHECK-NEXT:     |                Expected '}' to close statement block
// CHECK-NEXT:    6|  return 0;
