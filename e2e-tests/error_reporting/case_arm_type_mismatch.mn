# RUN: ! %sammine --file %full %O 2>&1 | %check %full
# CHECK: Case arms have incompatible types: expected i32, got f64

enum Color = Red | Green | Blue;

let main() -> i32 {
  let c: Color = Color::Red;
  let x: i32 = case c {
    Color::Red => 1,
    Color::Green => 3.14,
    Color::Blue => 3,
  };
  return 0;
}
