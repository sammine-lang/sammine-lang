# RUN: ! %sammine --file %full %O 2>&1 | %check %full
# CHECK:          |lateral_escape_deref_direct.mn:10:2
# CHECK-NEXT:    8|let bad(p: ptr<ptr<i32>>) -> i32 {
# CHECK-NEXT:    9|  let x : i32 = 42;
# CHECK-NEXT:   10|  *p = &x;
# CHECK-NEXT:     |  ──────┬
# CHECK-NEXT:     |        ╰─ Cannot store non-linear ptr<i32> through pointer dereference — may dangle after scope exit
# CHECK-NEXT:   11|  return 0;
# CHECK-NEXT:   12|}
# CHECK:      # Did something seems wrong? Report it via [https://codeberg.org/badumbatish/sammine-lang/issues]
# CHECK-NEXT: # Give us a screenshot of the error as well as your contextual source code
# CHECK-NEXT: --------------------------------------------------------------------------

# Test: storing a non-linear pointer directly through *p = &local
# must be rejected — p may point to a longer-lived location.

import std;

let bad(p: ptr<ptr<i32>>) -> i32 {
  let x : i32 = 42;
  *p = &x;
  return 0;
}

let main() -> i32 {
  return 0;
}
