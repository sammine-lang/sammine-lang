// RUN: ! %sammine --file %full %O 2>&1 | %check %full
// CHECK:          |immutable_reassign.mn:6:4
// CHECK-NEXT:    4|let main() -> i32 {
// CHECK-NEXT:    5|  let x: i32 = 5;
// CHECK-NEXT:    6|  x = 10;
// CHECK-NEXT:     |    ┬
// CHECK-NEXT:     |    ╰─ Cannot reassign immutable variable 'x'. Use 'let mut' or 'mut' to declare it as mutable
// CHECK-NEXT:    7|  return x;
// CHECK-NEXT:    8|}
// CHECK:      # Did something seems wrong? Report it via [https://codeberg.org/badumbatish/sammine-lang/issues]
// CHECK-NEXT: # Give us a screenshot of the error as well as your contextual source code
// CHECK-NEXT: --------------------------------------------------------------------------

let main() -> i32 {
  let x: i32 = 5;
  x = 10;
  return x;
}
