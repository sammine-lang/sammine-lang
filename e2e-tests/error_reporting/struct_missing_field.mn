# RUN: ! %sammine --file %full %O 2>&1 | %check %full
# CHECK:          |struct_missing_field.mn:10:28
# CHECK-NEXT:    8|
# CHECK-NEXT:    9|let main() -> i32 {
# CHECK-NEXT:   10|  let p: Point = Point { x: 1 };
# CHECK-NEXT:     |                            ┬
