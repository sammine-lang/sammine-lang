// RUN: ! %sammine --file %full %O 2>&1 | %check %full
// CHECK:          |case_non_exhaustive.mn:8:7
// CHECK-NEXT:    6|let main() -> i32 {
// CHECK-NEXT:    7|  let s: Shape = Shape::Circle(5);
// CHECK-NEXT:    8|  case s {
// CHECK-NEXT:     |       ┬
// CHECK-NEXT:     |       ╰─ Non-exhaustive case expression: missing variant(s) Point
// CHECK-NEXT:    9|    Shape::Circle(r) => r,
// CHECK-NEXT:   10|    Shape::Rect(w, h) => w,
// CHECK:      # Did something seems wrong? Report it via [https://codeberg.org/badumbatish/sammine-lang/issues]
// CHECK-NEXT: # Give us a screenshot of the error as well as your contextual source code
// CHECK-NEXT: --------------------------------------------------------------------------

type Shape = Circle(i32) | Rect(i32, i32) | Point;

let main() -> i32 {
  let s: Shape = Shape::Circle(5);
  case s {
    Shape::Circle(r) => r,
    Shape::Rect(w, h) => w,
  };
  return 0;
}
