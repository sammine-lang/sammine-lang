# RUN: ! %sammine --file %full %O 2>&1 | %check %full
# CHECK: Non-exhaustive case expression: missing variant(s) Point

enum Shape = Circle(i32) | Rect(i32, i32) | Point;

let main() -> i32 {
  let s: Shape = Shape::Circle(5);
  case s {
    Shape::Circle(r) => r,
    Shape::Rect(w, h) => w,
  };
  return 0;
}
