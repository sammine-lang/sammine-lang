# RUN: ! %sammine --file %full %O 2>&1 | %check %full
# CHECK:          |linear_branch_mismatch.mn:1:0
# CHECK:          |────────────────────────────────────────────────────┬
# CHECK-NEXT:     |                                                    ╰─ Linear variable 'p' is consumed in some branches but not others
# CHECK:         3|
# CHECK-NEXT:    4|let main() -> i32 {
# CHECK-NEXT:    5|  let p = alloc<i32>(1);
# CHECK-NEXT:    6|  *p = 10;
# CHECK-NEXT:    7|  if true {
# CHECK-NEXT:    8|    free(p);
# CHECK-NEXT:    9|  };
# CHECK:      # Did something seems wrong? Report it via [https://codeberg.org/badumbatish/sammine-lang/issues]
# CHECK-NEXT: # Give us a screenshot of the error as well as your contextual source code
# CHECK-NEXT: --------------------------------------------------------------------------

let main() -> i32 {
  let p = alloc<i32>(1);
  *p = 10;
  if true {
    free(p);
  };
  return 0;
}
