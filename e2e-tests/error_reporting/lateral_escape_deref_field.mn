// RUN: ! %sammine --file %full %O 2>&1 | %check %full
// CHECK:          |lateral_escape_deref_field.mn:16:3
// CHECK-NEXT:   14|let bad(h: ptr<Holder>) -> i32 {
// CHECK-NEXT:   15|  let x : i32 = 42;
// CHECK-NEXT:   16|  (*h).p = &x;
// CHECK-NEXT:     |   ─────────┬
// CHECK-NEXT:     |            ╰─ Cannot store non-linear ptr<i32> through pointer dereference — may dangle after scope exit
// CHECK-NEXT:   17|  return 0;
// CHECK-NEXT:   18|}
// CHECK:      # Did something seems wrong? Report it via [https://codeberg.org/badumbatish/sammine-lang/issues]
// CHECK-NEXT: # Give us a screenshot of the error as well as your contextual source code
// CHECK-NEXT: --------------------------------------------------------------------------

// Test: storing a non-linear pointer into a field through a pointer dereference
// must be rejected — the local dies when the function returns, but the
// dereferenced location may outlive it (lateral escape).

import std;

struct Holder {
  p: ptr<i32>,
  tag: i32,
};

let bad(h: ptr<Holder>) -> i32 {
  let x : i32 = 42;
  (*h).p = &x;
  return 0;
}

let main() -> i32 {
  return 0;
}
