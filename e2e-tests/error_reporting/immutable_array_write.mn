# RUN: ! %sammine --file %full %O 2>&1 | %check %full
# CHECK:          |immutable_array_write.mn:6:7
# CHECK-NEXT:    4|let main() -> i32 {
# CHECK-NEXT:    5|  let a: [i32; 3] = [1, 2, 3];
# CHECK-NEXT:    6|  a[0] = 99;
# CHECK-NEXT:     |       ┬
# CHECK-NEXT:     |       ╰─ Cannot write to index of immutable array 'a'. Use 'let mut' to declare it as mutable
# CHECK-NEXT:    7|  return 0;
# CHECK-NEXT:    8|}
# CHECK:      # Did something seems wrong? Report it via [https://codeberg.org/badumbatish/sammine-lang/issues]
# CHECK-NEXT: # Give us a screenshot of the error as well as your contextual source code
# CHECK-NEXT: --------------------------------------------------------------------------

let main() -> i32 {
  let a: [i32; 3] = [1, 2, 3];
  a[0] = 99;
  return 0;
}
