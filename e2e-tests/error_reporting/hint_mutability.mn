# RUN: ! %sammine --file %full %O 2>&1 | %check %full
# CHECK:          |hint_mutability.mn
# CHECK-NEXT:   17|  let x : i32 = 42;
# CHECK-NEXT:   18|  let p : ptr<i32> = &x;
# CHECK-NEXT:   19|  let mut q : ptr<i32> = p;
# CHECK-NEXT:     |                         ┬
# CHECK-NEXT:     |                         ╰─ Type mismatch: expression has type ptr<i32>, but variable declared as ptr<i32>
# CHECK-NEXT:     |                         ┬
# CHECK-NEXT:     |                         ╰─ note: expected a mutable value, but got an immutable one
# CHECK-NEXT:   20|  return 0;
# CHECK-NEXT:   21|}
# CHECK:      # Did something seems wrong? Report it via [https://codeberg.org/badumbatish/sammine-lang/issues]
# CHECK-NEXT: # Give us a screenshot of the error as well as your contextual source code
# CHECK-NEXT: --------------------------------------------------------------------------

let main() -> i32 {
  let x : i32 = 42;
  let p : ptr<i32> = &x;
  let mut q : ptr<i32> = p;
  return 0;
}
