# RUN: ! %sammine --file %full %O 2>&1 | %check %full
# CHECK: Pattern 'Shape::Circle' expects 1 bindings, got 0

type Shape = Circle(f64) | Rect(f64, f64) | Point;

let main() -> i32 {
  let s: Shape = Shape::Circle(1.0);
  let r: i32 = case s {
    Shape::Circle => 1,
    Shape::Rect(w, h) => 2,
    Shape::Point => 3,
  };
  return r;
}
