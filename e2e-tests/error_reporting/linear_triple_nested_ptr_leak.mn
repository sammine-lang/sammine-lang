# RUN: ! %sammine --file %full %O 2>&1 | %check %full
# CHECK: Linear variable 'c.*' must be consumed before scope exit

import std;

let main() -> i32 {
  let a: 'ptr<i32> = alloc<i32>(1);
  let b: 'ptr<'ptr<i32>> = alloc<'ptr<i32>>(1);
  let c: 'ptr<'ptr<'ptr<i32>>> = alloc<'ptr<'ptr<i32>>>(1);
  *a = 1;
  *b = a;
  *c = b;
  free(c);
  return 0;
}
