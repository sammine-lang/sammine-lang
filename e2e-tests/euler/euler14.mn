# RUN: %sammine --file %full %O && %T/%base.exe | %check %full
# CHECK: 837799

# Project Euler Problem 14: Longest Collatz sequence under 1,000,000

import std;

let collatz_len(n: i64, acc: i64) -> i64 {
  if n == 1 { acc }
  else if n % 2 == 0 { collatz_len(n / 2, acc + 1) }
  else { collatz_len(3 * n + 1, acc + 1) }
}

let find_max(i: i64, best_i: i64, best_cnt: i64) -> i64 {
  if i >= 1000000 { best_i }
  else {
    let cnt: i64 = collatz_len(i, 1);
    if cnt > best_cnt { find_max(i + 1, i, cnt) }
    else { find_max(i + 1, best_i, best_cnt) }
  }
}

let main() -> i32 {
  let result: i64 = find_max(1, 1, 1);
  std::printf("%lld\n", result);
  return 0;
}
