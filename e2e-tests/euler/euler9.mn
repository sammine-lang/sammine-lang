# RUN: %sammine --file %full %O && %T/%base.exe | %check %full
# CHECK:      31875000

# Project Euler Problem 9: Special Pythagorean triplet
# Find a*b*c where a+b+c=1000 and a^2+b^2=c^2

import std;

let check_b(a: i64, b: i64) -> i64 {
  let c : i64 = 1000 - a - b;
  if b >= c {
    0
  } else if a * a + b * b == c * c {
    a * b * c
  } else {
    check_b(a, b + 1)
  }
}

let check_a(a: i64) -> i64 {
  let result : i64 = check_b(a, a + 1);
  if result > 0 {
    result
  } else {
    check_a(a + 1)
  }
}

let main() -> i32 {
  let result : i64 = check_a(1);
  std::printf("%lld\n", result);
  return 0;
}
