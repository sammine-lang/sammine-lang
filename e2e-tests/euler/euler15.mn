# RUN: %sammine --file %full %O && %T/%base.exe | %check %full
# CHECK:      137846528820

# Project Euler Problem 15: Lattice paths in a 20x20 grid
# C(40, 20) computed iteratively to avoid overflow

import std;

let binom(n: i64, k: i64, i: i64, acc: i64) -> i64 {
  if i > k { acc }
  else { binom(n, k, i + 1, acc * (n - k + i) / i) }
}

let main() -> i32 {
  let result: i64 = binom(40, 20, 1, 1);
  std::printf("%lld\n", result);
  return 0;
}
