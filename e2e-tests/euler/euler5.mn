# RUN: %sammine --file %full %O && %T/%base.exe | %check %full
# CHECK: 232792560

# Project Euler Problem 5: Smallest multiple of all numbers 1 to 20

import std;

let gcd(a: i32, b: i32) -> i32 {
  if b == 0 { a } else { gcd(b, a % b) }
}

let lcm(a: i32, b: i32) -> i32 {
  a / gcd(a, b) * b
}

let lcm_range(n: i32, acc: i32) -> i32 {
  if n > 20 { acc } else { lcm_range(n + 1, lcm(acc, n)) }
}

let main() -> i32 {
  std::printf("%d\n", lcm_range(1, 1));
  return 0;
}
