# RUN: %sammine --file %full %O && %T/%base.exe | %check %full
# CHECK: 142913828922

# Project Euler Problem 10: Sum of all primes below 2,000,000

import std;

let is_prime_h(n: i64, d: i64) -> i64 {
  if d * d > n {
    1
  } else if n % d == 0 {
    0
  } else {
    is_prime_h(n, d + 1)
  }
}

let is_prime(n: i64) -> i64 {
  if n < 2 {
    0
  } else {
    is_prime_h(n, 2)
  }
}

let sum_primes(n: i64, limit: i64, acc: i64) -> i64 {
  if n >= limit {
    acc
  } else if is_prime(n) > 0 {
    sum_primes(n + 1, limit, acc + n)
  } else {
    sum_primes(n + 1, limit, acc)
  }
}

let main() -> i32 {
  let result : i64 = sum_primes(2, 2000000, 0);
  std::printf("%lld\n", result);
  0
}
