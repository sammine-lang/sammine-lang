# RUN: %sammine --file %full && ./%base.exe | %check %full
# CHECK: 70600674

# Project Euler Problem 11: Largest product in a 20x20 grid
# Uses partial application to parameterize direction — one prod and one guard
# function handle all 4 directions (horizontal, vertical, diagonal, anti-diagonal).

let g() -> arr<i32, 400> {
  return [8,2,22,97,38,15,0,40,0,75,4,5,7,78,52,12,50,77,91,8,49,49,99,40,17,81,18,57,60,87,17,40,98,43,69,48,4,56,62,0,81,49,31,73,55,79,14,29,93,71,40,67,53,88,30,3,49,13,36,65,52,70,95,23,4,60,11,42,69,24,68,56,1,32,56,71,37,2,36,91,22,31,16,71,51,67,63,89,41,92,36,54,22,40,40,28,66,33,13,80,24,47,32,60,99,3,45,2,44,75,33,53,78,36,84,20,35,17,12,50,32,98,81,28,64,23,67,10,26,38,40,67,59,54,70,66,18,38,64,70,67,26,20,68,2,62,12,20,95,63,94,39,63,8,40,91,66,49,94,21,24,55,58,5,66,73,99,26,97,17,78,78,96,83,14,88,34,89,63,72,21,36,23,9,75,0,76,44,20,45,35,14,0,61,33,97,34,31,33,95,78,17,53,28,22,75,31,67,15,94,3,80,4,62,16,14,9,53,56,92,16,39,5,42,96,35,31,47,55,58,88,24,0,17,54,24,36,29,85,57,86,56,0,48,35,71,89,7,5,44,44,37,44,60,21,58,51,54,17,58,19,80,81,68,5,94,47,69,28,73,92,13,86,52,17,77,4,89,55,40,4,52,8,83,97,35,99,16,7,97,57,32,16,26,26,79,33,27,98,66,88,36,68,87,57,62,20,72,3,46,33,67,46,55,12,32,63,93,53,69,4,42,16,73,38,25,39,11,24,94,72,18,8,46,29,32,40,62,76,36,20,69,36,41,72,30,23,88,34,62,99,69,82,67,59,85,74,4,36,16,20,73,35,29,78,31,90,1,74,31,49,71,48,86,81,16,23,57,5,54,1,70,54,71,83,51,54,69,16,92,33,48,61,43,52,1,89,19,67,48];
}

let max2(a: i32, b: i32) -> i32 {
  if a > b { a } else { b }
}

let at(grid: arr<i32, 400>, r: i32, c: i32) -> i32 {
  return grid[r * 20 + c];
}

# Generic product — dr/dc are the row/col step offsets
let prod(dr: i32, dc: i32, grid: arr<i32, 400>, r: i32, c: i32) -> i32 {
  return at(grid, r, c)
       * at(grid, r + dr, c + dc)
       * at(grid, r + dr * 2, c + dc * 2)
       * at(grid, r + dr * 3, c + dc * 3);
}

# Generic guard — checks that all 4 cells in direction (dr,dc) are in bounds
let in_bounds(v: i32) -> i32 {
  if v >= 0 { if v < 20 { 1 } else { 0 } } else { 0 }
}

let guard(dr: i32, dc: i32, r: i32, c: i32) -> i32 {
  if in_bounds(r + dr * 3) > 0 {
    if in_bounds(c + dc * 3) > 0 { 1 } else { 0 }
  } else { 0 }
}

# Generic check — iterates all (r,c) positions
let check(grid: arr<i32, 400>,
          p: (arr<i32, 400>, i32, i32) -> i32,
          gd: (i32, i32) -> i32,
          r: i32, c: i32, best: i32) -> i32 {
  if r >= 20 {
    best
  } else if c >= 20 {
    check(grid, p, gd, r + 1, 0, best)
  } else if gd(r, c) > 0 {
    let v: i32 = p(grid, r, c);
    check(grid, p, gd, r, c + 1, max2(best, v))
  } else {
    check(grid, p, gd, r, c + 1, best)
  }
}

let main() -> i32 {
  let grid: arr<i32, 400> = g();
  let b1: i32 = check(grid, prod(0, 1),  guard(0, 1),  0, 0, 0);
  let b2: i32 = check(grid, prod(1, 0),  guard(1, 0),  0, 0, b1);
  let b3: i32 = check(grid, prod(1, 1),  guard(1, 1),  0, 0, b2);
  let b4: i32 = check(grid, prod(1, -1), guard(1, -1), 0, 0, b3);
  printf("%d\n", b4);
  return 0;
}
