# RUN: %sammine --file %full %O && %T/%base.exe | %check %full
# CHECK:      6857

# Project Euler Problem 3: Largest prime factor of 600851475143

import std;

let find_factor(n: i64, d: i64) -> i64 {
  if d * d > n {
    n
  } else if n % d == 0 {
    find_factor(n / d, d)
  } else {
    find_factor(n, d + 1)
  }
}

let main() -> i32 {
  let result = find_factor(600851475143, 2);
  std::printf("%lld\n", result);
  return 0;
}
