# RUN: %sammine --file %full && ./%base.exe | %check %full
# CHECK: 4613732

let even_fib(a: i32, b: i32, sum: i32) -> i32 {
  if b > 4000000 {
    sum
  } else {
    let next_b = a + b;
    let next_sum = if next_b % 2 == 0 {
      sum + next_b
    } else {
      sum
    };
    even_fib(b, next_b, next_sum)
  }
}

let main() -> i32 {
  printf("%d\n", even_fib(0, 1, 0));
  return 0;
}
