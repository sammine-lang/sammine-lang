# RUN: %sammine --file %full && ./%base.exe | %check %full
# CHECK: 233168

# Project Euler Problem 1: Sum of multiples of 3 or 5 below 1000
let sum_multiples(n: i64, acc: i64) -> i64 {
  if n >= 1000 {
    acc
  } else if n % 3 == 0 || n % 5 == 0 {
    sum_multiples(n + 1, acc + n)
  } else {
    sum_multiples(n + 1, acc)
  }
}

let main() -> i64 {
  printf("%d\n", sum_multiples(0, 0));
  return 0;
}
