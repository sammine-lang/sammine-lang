# RUN: %sammine --file %full && ./%base.exe | %check %full
# CHECK: 23514624000

# Project Euler Problem 8: Greatest product of 13 adjacent digits

let product13(d: [i64;1000], i: i32, j: i32, acc: i64) -> i64 {
  if j >= 13 { acc } else { product13(d, i, j + 1, acc * d[i + j]) }
}

let find_max(d: [i64;1000], i: i32, best: i64) -> i64 {
  if i > 987 { best }
  else {
    let p : i64 = product13(d, i, 0, 1i64);
    if p > best { find_max(d, i + 1, p) }
    else { find_max(d, i + 1, best) }
  }
}

