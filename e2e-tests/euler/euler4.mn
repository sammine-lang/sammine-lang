# RUN: %sammine --file %full && ./%base.exe | %check %full
# CHECK: 906609

# Project Euler Problem 4: Largest palindrome from product of two 3-digit numbers
# Strategy: generate palindromes from largest to smallest, check factorability

# Mirror a 3-digit number into a 6-digit palindrome
# e.g., 906 -> 906609

import std;

let make_palindrome(n: i32) -> i32 {
  let d1  = n / 100;
  let d2  = (n / 10) % 10;
  let d3  = n % 10;
  n * 1000 + d3 * 100 + d2 * 10 + d1
}

# Try divisors from d down to 100, return p if both factors are 3-digit
let check_divisor(p: i32, d: i32) -> i32 {
  if d < 100 {
    0
  } else if p % d == 0 && p / d >= 100 && p / d <= 999 {
    p
  } else {
    check_divisor(p, d - 1)
  }
}

# Search palindromes from largest (half=999) to smallest (half=100)
let search(half: i32) -> i32 {
  if half < 100 {
    0
  } else {
    let result = check_divisor(make_palindrome(half), 999);
    if result > 0 {
      result
    } else {
      search(half - 1)
    }
  }
}

let main() -> i32 {
  printf("%d\n", search(999));
  return 0;
}
