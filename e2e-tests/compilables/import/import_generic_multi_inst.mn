// RUN: %sammine --file %dir/Inputs/has_generic.mn %O && %sammine_jit --diagnostics=dev --file %full %I -I %dir/Inputs | %check %full
// CHECK:      42
// CHECK-NEXT: 7
import has_generic;
import std;

let main() -> i32 {
  let a = has_generic::identity<i32>(42);
  let b = has_generic::identity<i64>(7);
  std::printf("%d\n", a);
  std::printf("%ld\n", b);
  return 0;
}
