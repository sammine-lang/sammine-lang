# RUN: %sammine --file %dir/Inputs/has_generic.mn %O && %sammine --diagnostics=dev --file %full %O %I && %T/%base.exe | %check %full
# CHECK: 42
# CHECK: 7
import has_generic;
import std;

let main() -> i32 {
  let a = has_generic::identity<i32>(42);
  let b = has_generic::identity<i64>(7);
  std::printf("%d\n", a);
  std::printf("%ld\n", b);
  return 0;
}
