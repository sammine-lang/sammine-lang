# RUN: ! %sammine --file %full %O --check 2>&1 | %check %full
# CHECK:          |unknown_module_alias.mn:7:2
# CHECK-NEXT:    5|
# CHECK-NEXT:    6|let main() -> i32 {
# CHECK-NEXT:    7|  x::foo();
# CHECK-NEXT:     |  ─────┬
# CHECK-NEXT:     |       ╰─ Module 'x' is not imported
# CHECK-NEXT:    8|  return 0;
# CHECK-NEXT:    9|}
# CHECK:      # Did something seems wrong? Report it via [https://codeberg.org/badumbatish/sammine-lang/issues]
# CHECK-NEXT: # Give us a screenshot of the error as well as your contextual source code
# CHECK-NEXT: --------------------------------------------------------------------------

# Using an alias that was never imported should produce a clear error

let main() -> i32 {
  x::foo();
  return 0;
}
