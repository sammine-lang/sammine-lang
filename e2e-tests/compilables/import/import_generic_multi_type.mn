// RUN: %sammine --file %dir/Inputs/has_generic_multi.mn %O && %sammine_jit --file %full %I -I %dir/Inputs | %check %full
// CHECK:      10
// CHECK-NEXT: 20

import has_generic_multi as lib;
import std;

let main() -> i32 {
  let a: i32 = lib::first<i32, i64>(10, 20i64);
  let b: i64 = lib::second<i32, i64>(10, 20i64);
  std::printf("%d\n", a);
  std::printf("%ld\n", b);
  return 0;
}
