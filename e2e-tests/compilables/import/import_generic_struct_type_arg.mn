# RUN: %sammine --file %dir/Inputs/has_generic_struct.mn %O && %sammine --file %dir/Inputs/has_generic.mn %O && %sammine --diagnostics=dev --file %full %O %I -I %dir/Inputs && %T/%base.exe | %check %full
# CHECK: 10
# CHECK: 20
import has_generic_struct as lib;
import has_generic;
import std;

let main() -> i32 {
  let p = lib::Point { x: 10, y: 20 };
  let q: lib::Point = has_generic::identity<lib::Point>(p);
  std::printf("%d\n", q.x);
  std::printf("%d\n", q.y);
  return 0;
}
