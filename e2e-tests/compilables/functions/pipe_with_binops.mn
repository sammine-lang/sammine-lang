# RUN: %sammine --file %full %O && %T/%base.exe | %check %full
# CHECK:      49
# CHECK-NEXT: 29
# CHECK-NEXT: 11

import std;

let print_i32(x: i32) {
  std::printf("%d\n", x);
}

let square(x: i32) -> i32 {
  return x * x;
}

let add(a: i32, b: i32) -> i32 {
  return a + b;
}

let main() -> i32 {
  3 + 4 |> square |> print_i32;

  2 + 3 |> add(24) |> print_i32;

  2 * 3 + 5 |> add(0) |> print_i32;

  return 0;
}
