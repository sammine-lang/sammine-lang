// RUN: %sammine --file %full %O && %T/%base.exe | %check %full
// CHECK:      51

import std;

let square(x: i32) -> i32 { return x * x; }
let double(x: i32) -> i32 { return x + x; }
let add(a: i32, b: i32) -> i32 { return a + b; }

let main() -> i32 {
  let result: i32 = 5 |> square |> double |> add(1);
  std::printf("%d\n", result);
  return 0;
}
