// RUN: %sammine -f %full %O --gpu=cuda --mlir-ir 2>&1 | %check %full
// Verify --gpu=cuda emits gpu.alloc/gpu.memcpy/gpu.dealloc in the wrapper.

kernel double_arr(a: [3]f64) -> [3]f64 {
  map(a, (x: f64) -> f64 { x * 2.0 })
}

let main() -> i32 {
  let a = [1.0, 2.0, 3.0];
  let b = double_arr(a);
  0
}

// The wrapper @double_arr should marshal host↔device:
// CHECK:      func.func private @double_arr
// CHECK:      gpu.alloc
// CHECK:      gpu.memcpy
// CHECK:      gpu.alloc
// CHECK:      gpu.memcpy
// CHECK:      call @__kernel_double_arr
// CHECK:      gpu.memcpy
// CHECK:      gpu.dealloc
// CHECK:      gpu.dealloc
