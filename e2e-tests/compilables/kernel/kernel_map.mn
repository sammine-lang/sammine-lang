// RUN: %sammine --file %full %O && %T/%base.exe | %check %full

import io;

kernel double_arr(a: [3]f64) -> [3]f64 {
  map(a, (x: f64) -> f64 { x * 2.0 })
}

let main() -> i32 {
  let a = [1.0, 2.0, 3.0];
  let b = double_arr(a);
  io::printf("%f\n", b[0]);
  io::printf("%f\n", b[1]);
  io::printf("%f\n", b[2]);
  0
}

// CHECK:      2.000000
// CHECK-NEXT: 4.000000
// CHECK-NEXT: 6.000000
