// RUN: %sammine --file %full %O && %T/sizeof_basic.exe | %check %full
// CHECK:      4
// CHECK-NEXT: 8
// CHECK-NEXT: 8
// CHECK-NEXT: 1

reuse printf(fmt : ptr<char>, ...) -> i32;
let main() -> i32 {
  printf("%ld\n", Sized<i32>());
  printf("%ld\n", Sized<i64>());
  printf("%ld\n", Sized<f64>());
  printf("%ld\n", Sized<bool>());
  return 0;
}
