# RUN: %sammine --file %full %O && %T/%base.exe | %check %full
# CHECK:      4
# CHECK-NEXT: 8

# User-defined typeclass with custom method name (not just sizeof)

reuse printf(fmt : ptr<char>, ...) -> i32;

typeclass MySize<T> {
  mysize() -> i64;
}

instance MySize<i32> {
  let mysize() -> i64 { 4 }
}

instance MySize<i64> {
  let mysize() -> i64 { 8 }
}

let main() -> i32 {
  printf("%ld\n", mysize<i32>());
  printf("%ld\n", mysize<i64>());
  return 0;
}
