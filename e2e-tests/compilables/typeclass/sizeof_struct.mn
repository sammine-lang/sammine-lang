# RUN: %sammine --file %full %O && %T/%base.exe | %check %full
# CHECK:      4
# CHECK-NEXT: 99

# Test: struct named 'T' — same name as the typeclass type parameter in Sized<T>.
# Verifies that sizeof<T>() resolves T to our struct, not the abstract param.

reuse printf(fmt : ptr<char>, ...) -> i32;

struct T { val : i32, };

instance Sized<T> {
  let Sized() -> i64 { 99 }
}

let main() -> i32 {
  printf("%ld\n", Sized<i32>());
  printf("%ld\n", Sized<T>());
  return 0;
}
