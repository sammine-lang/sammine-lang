# RUN: %sammine --file %full %O && %T/%base.exe | %check %full
# CHECK:      4
# CHECK-NEXT: 8

# A generic function that calls a typeclass method with its type parameter.

reuse printf(fmt : ptr<char>, ...) -> i32;

let print_size<T>(x: T) -> i64 {
  Sized<T>()
}

let main() -> i32 {
  printf("%ld\n", print_size(42));
  printf("%ld\n", print_size(3.14));
  return 0;
}
