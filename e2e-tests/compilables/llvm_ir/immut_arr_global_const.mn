// RUN: %sammine --file %full %O --llvm-ir pre 2>&1 | %check %full
// Immutable arrays are alloca'd on the stack so that &a returns a writable
// address (global constants would cause UB when written through a pointer).

let sum3(arr: [3]i32) -> i32 {
  arr[0] + arr[1] + arr[2]
}

let main() -> i32 {
  let a: [3]i32 = [10, 20, 30];
  return sum3(a);
}

// CHECK: define i32 @main()
// CHECK: alloca [3 x i32]
// CHECK: store i32 10
// CHECK: store i32 20
// CHECK: store i32 30
