# RUN: ! %sammine --file %full %O --diagnostics 2>&1 | %check %full
# CHECK: Cannot return 'a' of type '[HasPtr;1]': non-linear ptr<i32> in field 'p' in element

# Test: array of structs wrapping ptr<T> — 2 levels deep
struct HasPtr {
  p: ptr<i32>,
  tag: i32,
};

let bad() -> [HasPtr;1] {
  let x : i32 = 42;
  let q : ptr<i32> = &x;
  let h : HasPtr = HasPtr { p: q, tag: 1 };
  let a : [HasPtr;1] = [h];
  return a;
}

let main() -> i32 {
  return 0;
}
