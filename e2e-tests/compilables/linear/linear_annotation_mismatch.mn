// RUN: ! %sammine --file %full %O --diagnostics 2>&1 | %check %full
// CHECK:          |linear_annotation_mismatch.mn
// CHECK-NEXT:   15|
// CHECK-NEXT:   16|let main() -> i32 {
// CHECK-NEXT:   17|  let p : ptr<i32> = alloc<i32>(1);
// CHECK-NEXT:     |                     ───────────┬
// CHECK-NEXT:     |                                ╰─ Type mismatch: expression has type 'ptr<i32>, but variable declared as ptr<i32>
// CHECK-NEXT:     |                     ───────────┬
// CHECK-NEXT:     |                                ╰─ note: 'ptr<i32>' is a linear (owned) pointer, 'ptr<i32>' is non-linear — these are incompatible
// CHECK-NEXT:   18|  return 0;
// CHECK-NEXT:   19|}
// CHECK:      # Did something seems wrong? Report it via [https://codeberg.org/badumbatish/sammine-lang/issues]
// CHECK-NEXT: # Give us a screenshot of the error as well as your contextual source code
// CHECK-NEXT: --------------------------------------------------------------------------

let main() -> i32 {
  let p : ptr<i32> = alloc<i32>(1);
  return 0;
}
