# RUN: ! %sammine --file %full %O --diagnostics 2>&1 | %check %full
# CHECK:          |linear_struct_double_use.mn
# CHECK-NEXT:   10|  let p = alloc<i32>(1);
# CHECK-NEXT:   11|  *p = 42;
# CHECK-NEXT:   12|  let b : Box = Box { data: p, tag: 1 };
# CHECK-NEXT:     |                            ────────┬
# CHECK-NEXT:     |                                    ╰─ 'p' was moved into struct here
# CHECK-NEXT:     |  ──────────────────────────────────┬
# CHECK-NEXT:     |                                    ╰─ Linear variable 'b.data' must be consumed before scope exit (use free() to deallocate)
# CHECK-NEXT:   13|  free(p);
# CHECK-NEXT:     |  ─────┬
# CHECK-NEXT:     |       ╰─ Cannot use linear variable 'p' — it was already moved into struct previously
# CHECK-NEXT:   14|  return 0;
# CHECK-NEXT:   15|}
# CHECK:      # Did something seems wrong? Report it via [https://codeberg.org/badumbatish/sammine-lang/issues]
# CHECK-NEXT: # Give us a screenshot of the error as well as your contextual source code
# CHECK-NEXT: --------------------------------------------------------------------------

struct Box {
  data: 'ptr<i32>,
  tag: i32,
};

let main() -> i32 {
  let p = alloc<i32>(1);
  *p = 42;
  let b : Box = Box { data: p, tag: 1 };
  free(p);
  return 0;
}
