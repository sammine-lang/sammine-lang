// RUN: ! %sammine --file %full %O --diagnostics 2>&1 | %check %full
// CHECK:          |linear_nested_enum_in_struct_return.mn:17:2
// CHECK-NEXT:   15|  let mp : MaybePtr = MaybePtr::Some(q);
// CHECK-NEXT:   16|  let h : Holder = Holder { m: mp, tag: 1 };
// CHECK-NEXT:   17|  return h;
// CHECK-NEXT:     |  ───────┬
// CHECK-NEXT:     |         ╰─ Cannot return 'h' of type 'Holder': non-linear ptr<i32> in variant 'Some' in field 'm' (may reference a local variable)
// CHECK-NEXT:   18|}
// CHECK-NEXT:   19|
// CHECK:      # Did something seems wrong? Report it via [https://codeberg.org/badumbatish/sammine-lang/issues]
// CHECK-NEXT: # Give us a screenshot of the error as well as your contextual source code
// CHECK-NEXT: --------------------------------------------------------------------------

// Test: struct wrapping enum wrapping ptr<T> — 2 levels deep
type MaybePtr = Some(ptr<i32>) | None;

struct Holder {
  m: MaybePtr,
  tag: i32,
};

let bad() -> Holder {
  let x : i32 = 42;
  let q : ptr<i32> = &x;
  let mp : MaybePtr = MaybePtr::Some(q);
  let h : Holder = Holder { m: mp, tag: 1 };
  return h;
}

let main() -> i32 {
  return 0;
}
