// RUN: %sammine --file %full %O && %T/%base.exe | %check %full
// CHECK:      42

import std;

struct Box {
  data: 'ptr<i32>,
  tag: i32,
};

let main() -> i32 {
  let a = Box { data: alloc<i32>(1), tag: 1 };
  *a.data = 42;
  let b = Box { data: a.data, tag: a.tag };
  std::printf("%d", *b.data);
  free(b.data);
  return 0;
}
