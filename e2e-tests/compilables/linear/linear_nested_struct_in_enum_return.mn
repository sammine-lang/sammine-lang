// RUN: ! %sammine --file %full %O --diagnostics 2>&1 | %check %full
// CHECK:          |linear_nested_struct_in_enum_return.mn:17:2
// CHECK-NEXT:   15|  let h : HasPtr = HasPtr { p: q, tag: 1 };
// CHECK-NEXT:   16|  let m : MaybeHasPtr = MaybeHasPtr::Some(h);
// CHECK-NEXT:   17|  return m;
// CHECK-NEXT:     |  ───────┬
// CHECK-NEXT:     |         ╰─ Cannot return 'm' of type 'MaybeHasPtr': non-linear ptr<i32> in field 'p' in variant 'Some' (may reference a local variable)
// CHECK-NEXT:   18|}
// CHECK-NEXT:   19|
// CHECK:      # Did something seems wrong? Report it via [https://codeberg.org/badumbatish/sammine-lang/issues]
// CHECK-NEXT: # Give us a screenshot of the error as well as your contextual source code
// CHECK-NEXT: --------------------------------------------------------------------------

// Test: enum wrapping struct wrapping ptr<T> — 2 levels deep
struct HasPtr {
  p: ptr<i32>,
  tag: i32,
};

type MaybeHasPtr = Some(HasPtr) | None;

let bad() -> MaybeHasPtr {
  let x : i32 = 42;
  let q : ptr<i32> = &x;
  let h : HasPtr = HasPtr { p: q, tag: 1 };
  let m : MaybeHasPtr = MaybeHasPtr::Some(h);
  return m;
}

let main() -> i32 {
  return 0;
}
