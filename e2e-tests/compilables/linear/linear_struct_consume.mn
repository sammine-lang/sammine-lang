// RUN: %sammine --file %full %O && %T/%base.exe | %check %full
// CHECK:      42

import std;

struct Box {
  data: 'ptr<i32>,
  tag: i32,
};

let main() -> i32 {
  let p = alloc<i32>(1);
  *p = 42;
  let b : Box = Box { data: p, tag: 1 };
  let v : i32 = *(b.data);
  free(b.data);
  std::printf("%d\n", v);
  return 0;
}
