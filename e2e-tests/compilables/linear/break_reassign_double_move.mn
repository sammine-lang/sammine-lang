# RUN: ! %sammine --file %full %O --diagnostics 2>&1 | %check %full
# CHECK:          |break_reassign_double_move.mn
# CHECK-NEXT:   10|  let p = alloc<i32>(1);
# CHECK-NEXT:   11|  *p = 42;
# CHECK-NEXT:   12|  let q = p;
# CHECK-NEXT:     |  ────────┬
# CHECK-NEXT:     |          ╰─ 'p' was moved here
# CHECK-NEXT:   13|  let r = p;
# CHECK-NEXT:     |  ────────┬
# CHECK-NEXT:     |          ╰─ Cannot use linear variable 'p' — it was already moved previously
# CHECK-NEXT:   14|  free(q);
# CHECK-NEXT:   15|  free(r);
# CHECK:      # Did something seems wrong? Report it via [https://codeberg.org/badumbatish/sammine-lang/issues]
# CHECK-NEXT: # Give us a screenshot of the error as well as your contextual source code
# CHECK-NEXT: --------------------------------------------------------------------------

# CORRECT: Two moves from same source should fail.
# let q = p consumes p. Then let r = p should fail.

import std;

let main() -> i32 {
  let p = alloc<i32>(1);
  *p = 42;
  let q = p;
  let r = p;
  free(q);
  free(r);
  return 0;
}
