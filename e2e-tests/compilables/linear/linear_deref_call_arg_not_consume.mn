// RUN: %sammine --file %full %O && %T/%base.exe | %check %full
// CHECK:      84

// Passing *a to a function should NOT consume the linear pointer a.
// a must still be freed afterward.

import std;

let double_it(x: i32) -> i32 {
  return x * 2;
}

let main() -> i32 {
  let a = alloc<i32>(1);
  *a = 42;
  let result : i32 = double_it(*a);
  free(a);
  std::printf("%d\n", result);
  return 0;
}
