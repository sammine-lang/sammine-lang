// RUN: %sammine --file %full %O && %T/%base.exe | %check %full
// CHECK:      99

import std;

// Function returning a linear pointer — caller must free.
let make_ptr() -> 'ptr<i32> {
  let p = alloc<i32>(1);
  *p = 99;
  return p;
}

let main() -> i32 {
  let p = make_ptr();
  let v : i32 = *p;
  free(p);
  std::printf("%d\n", v);
  return 0;
}
