# RUN: %sammine --file %full %O && %T/%base.exe | %check %full
# CHECK: 42

# Tuple with a linear pointer: destructure, free the pointer, use non-linear part.

import std;

let main() -> i32 {
  let p = alloc<i32>(1);
  *p = 42;
  let t = (p, 10);
  let (a, b) = t;
  let v : i32 = *a;
  free(a);
  std::printf("%d\n", v);
  return 0;
}
