// RUN: ! %sammine --file %full %O --diagnostics 2>&1 | %check %full
// CHECK:          |break_dispatch_struct_field_extract.mn
// CHECK-NEXT:   16|  *p = 42;
// CHECK-NEXT:   17|  let b : Box = Box { data: p, tag: 1 };
// CHECK-NEXT:   18|  let q : 'ptr<i32> = b.data;
// CHECK-NEXT:     |  ─────────────────────────┬
// CHECK-NEXT:     |                           ╰─ 'b.data' was moved here
// CHECK-NEXT:   19|  let r : 'ptr<i32> = b.data;
// CHECK-NEXT:     |  ─────────────────────────┬
// CHECK-NEXT:     |                           ╰─ Cannot use linear variable 'b.data' — it was already moved previously
// CHECK-NEXT:   20|  let v : i32 = *q;
// CHECK-NEXT:   21|  free(q);
// CHECK:      # Did something seems wrong? Report it via [https://codeberg.org/badumbatish/sammine-lang/issues]
// CHECK-NEXT: # Give us a screenshot of the error as well as your contextual source code
// CHECK-NEXT: --------------------------------------------------------------------------

// CORRECT: Extract a linear pointer from a struct field, then extract again.
// Second b.data extraction is caught — the field was already consumed.

import std;

struct Box {
  data: 'ptr<i32>,
  tag: i32,
};

let main() -> i32 {
  let p = alloc<i32>(1);
  *p = 42;
  let b : Box = Box { data: p, tag: 1 };
  let q : 'ptr<i32> = b.data;
  let r : 'ptr<i32> = b.data;
  let v : i32 = *q;
  free(q);
  free(r);
  std::printf("%d\n", v);
  return 0;
}
