# RUN: ! %sammine --file %full %O --diagnostics 2>&1 | %check %full
# CHECK: already been consumed

# CORRECT: Passing linear pointer to a consuming function should
# consume it. Freeing it after should be an error.

import std;

let consume_ptr(p: 'ptr<i32>) -> i32 {
  let v : i32 = *p;
  free(p);
  return v;
}

let main() -> i32 {
  let p = alloc<i32>(1);
  *p = 42;
  let v : i32 = consume_ptr(p);
  free(p);
  std::printf("%d
", v);
  return 0;
}
