// RUN: ! %sammine --file %full %O --diagnostics 2>&1 | %check %full
// CHECK:          |break_reassign_call_then_free.mn
// CHECK-NEXT:   16|  let p = alloc<i32>(1);
// CHECK-NEXT:   17|  *p = 42;
// CHECK-NEXT:   18|  let v : i32 = consume_ptr(p);
// CHECK-NEXT:     |                            ┬
// CHECK-NEXT:     |                            ╰─ 'p' was passed to function here
// CHECK-NEXT:   19|  free(p);
// CHECK-NEXT:     |  ─────┬
// CHECK-NEXT:     |       ╰─ Cannot use linear variable 'p' — it was already passed to function previously
// CHECK-NEXT:   20|  std::printf("%d
// CHECK-NEXT:   21|", v);
// CHECK:      # Did something seems wrong? Report it via [https://codeberg.org/badumbatish/sammine-lang/issues]
// CHECK-NEXT: # Give us a screenshot of the error as well as your contextual source code
// CHECK-NEXT: --------------------------------------------------------------------------

// CORRECT: Passing linear pointer to a consuming function should
// consume it. Freeing it after should be an error.

import std;

let consume_ptr(p: 'ptr<i32>) -> i32 {
  let v : i32 = *p;
  free(p);
  return v;
}

let main() -> i32 {
  let p = alloc<i32>(1);
  *p = 42;
  let v : i32 = consume_ptr(p);
  free(p);
  std::printf("%d
", v);
  return 0;
}
