# RUN: ! %sammine --file %full %O --diagnostics 2>&1 | %check %full
# CHECK:          |linear_while_outer.mn
# CHECK-NEXT:    3|
# CHECK-NEXT:    4|let main() -> i32 {
# CHECK-NEXT:    5|  let p = alloc<i32>(1);
# CHECK-NEXT:     |  ───────────────────┬
# CHECK-NEXT:     |                     ╰─ Linear variable 'p' must be consumed before scope exit (use free() to deallocate)
# CHECK-NEXT:    6|  let mut i : i32 = 0;
# CHECK-NEXT:    7|  while i < 3 {
# CHECK-NEXT:    8|    free(p);
# CHECK-NEXT:     |    ─────┬
# CHECK-NEXT:     |         ╰─ Cannot consume linear variable 'p' inside a loop (defined outside the loop)
# CHECK-NEXT:    9|    i = i + 1;
# CHECK-NEXT:   10|  };
# CHECK:      # Did something seems wrong? Report it via [https://codeberg.org/badumbatish/sammine-lang/issues]
# CHECK-NEXT: # Give us a screenshot of the error as well as your contextual source code
# CHECK-NEXT: --------------------------------------------------------------------------

let main() -> i32 {
  let p = alloc<i32>(1);
  let mut i : i32 = 0;
  while i < 3 {
    free(p);
    i = i + 1;
  };
  return 0;
}
