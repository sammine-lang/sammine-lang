# RUN: %sammine --file %full %O && %T/%base.exe | %check %full
# CHECK: done

import std;

enum Color = Red | Green | Blue;

let main() -> i32 {
  let p = alloc<i32>(1);
  let c : Color = Red;
  case c {
    Color::Red => free(p),
    Color::Green => free(p),
    Color::Blue => free(p),
  };
  std::printf("done\n");
  return 0;
}
