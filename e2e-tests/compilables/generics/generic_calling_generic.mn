# RUN: %sammine --file %full %O && %T/%base.exe | %check %full
# CHECK:      42
# CHECK-NEXT: 3.14

import std;

let identity<T>(x: T) -> T { x }

let apply_identity<T>(x: T) -> T {
  identity<T>(x)
}

let main() -> i32 {
  std::printf("%d\n", apply_identity<i32>(42));
  std::printf("%.2f\n", apply_identity<f64>(3.14));
  return 0;
}
