// RUN: %sammine --file %full %O && %T/%base.exe | %check %full
// CHECK:      line written ok

import io;

let main() -> i32 {
  let content: ptr<char> = "line written ok\n";
  io::write_file("/tmp/sammine_test_handle.txt", content, 16);

  let mut f: 'ptr<char> = io::open("/tmp/sammine_test_handle.txt", "r");
  let mut buf: ptr<char> = "";
  let mut line_len: i64 = 0;

  f = io::file_read_line(f, &buf, &line_len);
  io::println(buf);

  io::close(f);
  0
}
