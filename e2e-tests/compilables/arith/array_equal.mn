# RUN: %sammine --file %full %O && %T/%base.exe | %check %full
# CHECK:      same arrays equal: 1
# CHECK-NEXT: same arrays not-equal: 0
# CHECK-NEXT: diff arrays equal: 0
# CHECK-NEXT: diff arrays not-equal: 1

import std;

let main() -> i32 {
  let a : [3]i32 = [1, 2, 3];
  let b : [3]i32 = [1, 2, 3];

  if a == b {
    std::printf("same arrays equal: 1\n");
  } else {
    std::printf("same arrays equal: 0\n");
  };

  if a != b {
    std::printf("same arrays not-equal: 1\n");
  } else {
    std::printf("same arrays not-equal: 0\n");
  };

  let c : [3]i32 = [1, 2, 99];

  if a == c {
    std::printf("diff arrays equal: 1\n");
  } else {
    std::printf("diff arrays equal: 0\n");
  };

  if a != c {
    std::printf("diff arrays not-equal: 1\n");
  } else {
    std::printf("diff arrays not-equal: 0\n");
  };

  return 0;
}
