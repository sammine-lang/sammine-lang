# RUN: %sammine --file %full %O && %T/%base.exe | %check %full
# CHECK: 3000000000
# CHECK-NEXT: 1000000000
# CHECK-NEXT: 3000000000
# CHECK-NEXT: 2

import std;

let main() -> i32 {
  let a : i64 = 1000000000;
  let b : i64 = 2000000000;
  std::printf("%ld\n", a + b);
  std::printf("%ld\n", b - a);
  std::printf("%ld\n", a * 3);
  std::printf("%ld\n", b / a);
  return 0;
}
