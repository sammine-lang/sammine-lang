# RUN: %sammine --file %full && ./%base.exe | %check %full
# CHECK: not equal
# CHECK: equal

import std;

let main() -> i32 {
  let a : f64 = 3.14;
  let b : f64 = 2.72;
  if a != b {
    std::printf("not equal\n");
  } else {
    std::printf("equal\n");
  };

  let c : f64 = 1.5;
  let d : f64 = 1.5;
  if c != d {
    std::printf("not equal\n");
  } else {
    std::printf("equal\n");
  };

  return 0;
}
