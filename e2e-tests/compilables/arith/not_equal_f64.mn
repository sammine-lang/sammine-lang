// RUN: %sammine --file %full %O && %T/%base.exe | %check %full
// CHECK:      not equal
// CHECK-NEXT: equal

import std;

let main() -> i32 {
  let a : f64 = 3.14;
  let b : f64 = 2.72;
  if a != b {
    std::printf("not equal\n");
  } else {
    std::printf("equal\n");
  };

  let c : f64 = 1.5;
  let d : f64 = 1.5;
  if c != d {
    std::printf("not equal\n");
  } else {
    std::printf("equal\n");
  };

  return 0;
}
