// RUN: %sammine_jit --file %full | %check %full
// CHECK:      15
// CHECK-NEXT: 5
// CHECK-NEXT: 50
// CHECK-NEXT: 2

import std;

let main() -> i32 {
  let a : i32 = 10;
  let b : i32 = 5;
  std::printf("%d\n", a + b);
  std::printf("%d\n", a - b);
  std::printf("%d\n", a * b);
  std::printf("%d\n", a / b);
  return 0;
}
