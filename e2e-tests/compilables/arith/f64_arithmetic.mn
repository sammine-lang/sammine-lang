# RUN: %sammine --file %full %O && %T/%base.exe | %check %full
# CHECK:      14.000000
# CHECK-NEXT: 7.000000
# CHECK-NEXT: 36.750000
# CHECK-NEXT: 3.000000

import std;

let main() -> i32 {
  let a : f64 = 10.5;
  let b : f64 = 3.5;
  std::printf("%f\n", a + b);
  std::printf("%f\n", a - b);
  std::printf("%f\n", a * b);
  std::printf("%f\n", a / b);
  return 0;
}
