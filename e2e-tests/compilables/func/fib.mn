# RUN: %sammine --file %full %O && %T/%base.exe | %check %full
# CHECK: 34
# CHECK-NEXT: 34

import std;

let fib_v1(x: i32) -> i32 {
  if x == 0 || x == 1 {
    return x;
  } else {
    return fib_v1(x-1) + fib_v1(x-2);
  }
}

let fib_v2(x: i32) -> i32 {
  if x == 0 || x == 1 {
    x
  } else {
    fib_v2(x-1) + fib_v2(x-2)
  }
}

let main() -> i32 {
  std::printf("%d\n", fib_v1(9));
  std::printf("%d\n", fib_v2(9));
  return 0;
}
