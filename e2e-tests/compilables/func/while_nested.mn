# RUN: %sammine --file %full %O && %T/%base.exe | %check %full
# CHECK: 1 1
# CHECK: 1 2
# CHECK: 2 1
# CHECK: 2 2

import std;

let main() -> i32 {
  let mut i: i32 = 1;
  while i <= 2 {
    let mut j: i32 = 1;
    while j <= 2 {
      std::printf("%d %d\n", i, j);
      j = j + 1;
    };
    i = i + 1;
  };
  return 0;
}
