// RUN: %sammine_jit --file %full | %check %full
// CHECK:      1 1
// CHECK-NEXT: 1 2
// CHECK-NEXT: 2 1
// CHECK-NEXT: 2 2

import std;

let main() -> i32 {
  let ip: 'ptr<i32> = alloc<i32>(1);
  *ip = 1;
  while *ip <= 2 {
    let jp: 'ptr<i32> = alloc<i32>(1);
    *jp = 1;
    while *jp <= 2 {
      std::printf("%d %d\n", *ip, *jp);
      *jp = *jp + 1;
    };
    free(jp);
    *ip = *ip + 1;
  };
  free(ip);
  return 0;
}
