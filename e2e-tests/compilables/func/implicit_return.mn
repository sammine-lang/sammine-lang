# RUN: %sammine --file %full %O && %T/%base.exe | %check %full
# CHECK:      233168

# Test implicit return - no explicit 'return' keyword needed

import std;

let sum_multiples(n: i32, acc: i32) -> i32 {
  if n >= 1000 {
    acc
  } else if n % 3 == 0 || n % 5 == 0 {
    sum_multiples(n + 1, acc + n)
  } else {
    sum_multiples(n + 1, acc)
  }
}

let main() -> i32 {
  std::printf("%d\n", sum_multiples(0, 0));
  0
}
