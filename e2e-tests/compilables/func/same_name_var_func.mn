# RUN: ! %sammine --file %full %O --diagnostics 2>&1 | %check %full
# CHECK:          |same_name_var_func.mn:3:4
# CHECK:         3|let f() -> i32 {
# CHECK-NEXT:     |    ─────────┬
# CHECK-NEXT:     |             ╰─ [SCOPE]: The firstly defined `f` is here
# CHECK-NEXT:    4|  return 0;
# CHECK-NEXT:    5|}
# CHECK-NEXT: --------------------------------------------------------------------------
# CHECK-NEXT:     |same_name_var_func.mn:8:6
# CHECK-NEXT:    6|
# CHECK-NEXT:    7|let main() -> i32 {
# CHECK-NEXT:    8|  let f = 1;
# CHECK-NEXT:     |      ┬
# CHECK-NEXT:     |      ╰─ [SCOPE]: The name `f` has been introduced before
# CHECK-NEXT:    9|  return 0;
# CHECK-NEXT:   10|}
# CHECK:      # Did something seems wrong? Report it via [https://codeberg.org/badumbatish/sammine-lang/issues]
# CHECK-NEXT: # Give us a screenshot of the error as well as your contextual source code
# CHECK-NEXT: --------------------------------------------------------------------------
let f() -> i32 {
  return 0;
}

let main() -> i32 {
  let f = 1;
  return 0;
}
