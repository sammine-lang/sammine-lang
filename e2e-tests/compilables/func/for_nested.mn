// RUN: %sammine_jit --file %full | %check %full
// CHECK:      0 0
// CHECK-NEXT: 0 1
// CHECK-NEXT: 1 0
// CHECK-NEXT: 1 1
// CHECK-NEXT: 2 0
// CHECK-NEXT: 2 1

import std;

let main() -> i32 {
  for i in 0i64..3 {
    for j in 0i64..2 {
      std::printf("%ld %ld\n", i, j);
    };
  };
  return 0;
}
