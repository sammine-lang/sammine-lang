# RUN: %sammine --file %full %O && %T/%base.exe | %check %full
# CHECK: 8
# CHECK-NEXT: 14
# CHECK-NEXT: 6
# CHECK-NEXT: 40
# CHECK-NEXT: 2

import std;

let main() -> i32 {
  let a: i32 = 10;
  let b: i32 = 12;

  std::printf("%d\n", a & b);
  std::printf("%d\n", a | b);
  std::printf("%d\n", a ^ b);
  std::printf("%d\n", a << 2);
  std::printf("%d\n", a >> 2);

  return 0;
}
