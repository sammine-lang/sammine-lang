// RUN: %sammine_jit --file %full | %check %full
// CHECK:      5
// CHECK-NEXT: 4
// CHECK-NEXT: 3
// CHECK-NEXT: 2
// CHECK-NEXT: 1

import std;

let main() -> i32 {
  let ip: 'ptr<i32> = alloc<i32>(1);
  *ip = 5;
  while *ip > 0 {
    std::printf("%d\n", *ip);
    *ip = *ip - 1;
  };
  free(ip);
  return 0;
}
