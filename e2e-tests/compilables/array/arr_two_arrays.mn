// RUN: %sammine --file %full %O && %T/%base.exe | %check %full
// CHECK:      10
// CHECK-NEXT: 100
// CHECK-NEXT: not equal
// CHECK-NEXT: equal

import std;

let main() -> i32 {
  let a : [3]i32 = [10, 20, 30];
  let b : [3]i32 = [100, 200, 300];
  std::printf("%d\n", (*&a)[0]);
  std::printf("%d\n", (*&b)[0]);
  if &a == &b {
    std::printf("equal\n");
  } else {
    std::printf("not equal\n");
  };
  if &a == &a {
    std::printf("equal\n");
  } else {
    std::printf("not equal\n");
  };
  return 0;
}
