# CHECK-NEXT:    7|  let a : [3]i32 = [10, 20, 30];
# CHECK-NEXT:    8|  std::printf("%d\n", a[5]);
# CHECK-NEXT:     |                      ──┬
# CHECK-NEXT:     |                        ╰─ Array index out of bounds: index 5 on array of size 3
# CHECK-NEXT:    9|  return 0;
# CHECK-NEXT:   10|}
# CHECK:      # Did something seems wrong? Report it via [https://codeberg.org/badumbatish/sammine-lang/issues]
