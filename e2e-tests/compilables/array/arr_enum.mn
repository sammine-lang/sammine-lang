# RUN: %sammine --file %full %O && %T/%base.exe | %check %full
# CHECK: circle r: 5
# CHECK: rect w: 3, h: 4
# CHECK: empty

import std;

enum Shape = Circle(i32) | Rect(i32, i32) | Empty;

let describe(s: Shape) -> i32 {
  case s {
    Shape::Circle(r) => std::printf("circle r: %d\n", r),
    Shape::Rect(w, h) => std::printf("rect w: %d, h: %d\n", w, h),
    Shape::Empty => std::printf("empty\n"),
  };
  return 0;
}

let main() -> i32 {
  let a : [Shape; 3] = [Shape::Circle(5), Shape::Rect(3, 4), Shape::Empty];
  describe(a[0]);
  describe(a[1]);
  describe(a[2]);
  return 0;
}
