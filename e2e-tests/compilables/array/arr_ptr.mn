// RUN: %sammine_jit --file %full | %check %full
// CHECK:      100
// CHECK-NEXT: 200
// CHECK-NEXT: 999

import std;

let main() -> i32 {
  let x : i32 = 100;
  let y : i32 = 200;
  let z : i32 = 300;
  let a : [3]ptr<i32> = [&x, &y, &z];
  std::printf("%d\n", *a[0]);
  std::printf("%d\n", *a[1]);
  // Write through pointer from array element
  let w : i32 = 999;
  let ap : 'ptr<ptr<i32>> = alloc<ptr<i32>>(3);
  ap[0] = &x;
  ap[1] = &y;
  ap[2] = &w;
  std::printf("%d\n", *ap[2]);
  free(ap);
  return 0;
}
