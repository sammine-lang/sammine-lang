import std;

let main() -> i32 {
  let a : [4]i32 = [0...3];
  std::printf("%d\n", a[0]);
  std::printf("%d\n", a[1]);
  std::printf("%d\n", a[2]);
  std::printf("%d\n", a[3]);
  return 0;
}
