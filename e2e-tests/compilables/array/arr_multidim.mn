# RUN: %sammine --file %full %O && %T/%base.exe | %check %full
# CHECK:      2
# CHECK-NEXT: 3
# CHECK-NEXT: 4
# CHECK-NEXT: 6

import std;

let dims(a: [2][3]i32) -> (i32, i32) {
  (len(a), len(a[0]))
}

let main() -> i32 {
  let a : [2][3]i32 = [[1, 2, 3], [4, 5, 6]];
  let (rows, cols) = dims(a);
  std::printf("%d\n", rows);
  std::printf("%d\n", cols);
  std::printf("%d\n", a[1][0]);
  std::printf("%d\n", a[1][2]);
  return 0;
}
