# CHECK: got B
# CHECK: got C
import dummy_enum;
import std;

let main() -> i32 {
  let x = A;
  let y: dummy_enum::dummy = B;
  let z: dummy_enum::dummy = C;
  case x {
    A => std::printf("got A\n"),
    B => std::printf("got B\n"),
    C => std::printf("got C\n"),
  };
  case y {
    A => std::printf("got A\n"),
    B => std::printf("got B\n"),
    C => std::printf("got C\n"),
  };
  case z {
    A => std::printf("got A\n"),
    B => std::printf("got B\n"),
    C => std::printf("got C\n"),
  };
  return 0;
}
