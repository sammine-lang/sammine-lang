# RUN: %sammine --file %full %O && %T/%base.exe | %check %full
# CHECK:      has value: 42
# CHECK-NEXT: no value

import std;

let main() -> i32 {
  let x: Option<i32> = Some(42);
  let y: Option<i32> = None;

  case x {
    Some(v) => std::printf("has value: %d\n", v),
    None => std::printf("no value\n"),
  };

  case y {
    Some(v) => std::printf("has value: %d\n", v),
    None => std::printf("no value\n"),
  };

  return 0;
}
