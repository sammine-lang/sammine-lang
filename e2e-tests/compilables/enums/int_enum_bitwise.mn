# RUN: %sammine --file %full %O && %T/%base.exe | %check %full
# CHECK: 3
# CHECK-NEXT: 7
# CHECK-NEXT: 6

import std;

type Flags = Read(1) | Write(2) | Exec(4);

let main() -> i32 {
  let rw: Flags = Read | Write;
  std::printf("%d\n", rw);

  let all: Flags = Read | Write | Exec;
  std::printf("%d\n", all);

  let wx: Flags = Write | Exec;
  std::printf("%d\n", wx);

  return 0;
}
