# RUN: %sammine --file %full %O && %T/%base.exe | %check %full
# CHECK:      has value: 42
# CHECK-NEXT: no value

import std;

type Option<T> = Some(T) | None;

let main() -> i32 {
  let x: Option<i32> = Option<i32>::Some(42);
  let y: Option<i32> = Option<i32>::None;

  case x {
    Option<i32>::Some(v) => std::printf("has value: %d\n", v),
    Option<i32>::None => std::printf("no value\n"),
  };

  case y {
    Option<i32>::Some(v) => std::printf("has value: %d\n", v),
    Option<i32>::None => std::printf("no value\n"),
  };

  return 0;
}
