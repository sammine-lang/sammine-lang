// RUN: %sammine --file %full %O && %T/%base.exe | %check %full
// CHECK:      4294967296
// CHECK-NEXT: 0

import std;

type Big: i64 = Large(4294967296) | Small(0);

let main() -> i32 {
  let l: Big = Large;
  let s: Big = Small;
  std::printf("%ld\n", l);
  std::printf("%ld\n", s);
  return 0;
}
