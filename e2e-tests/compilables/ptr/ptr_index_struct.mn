// RUN: %sammine --file %full %O && %T/%base.exe | %check %full
// CHECK:      10
// CHECK-NEXT: 20

import std;

struct Point {
  x: i32,
  y: i32,
};

let main() -> i32 {
  let mut p : 'ptr<Point> = alloc<Point>(2);
  p[0] = Point { x: 10, y: 11 };
  p[1] = Point { x: 20, y: 21 };
  std::printf("%d\n", p[0].x);
  std::printf("%d\n", p[1].x);
  free(p);
  return 0;
}
