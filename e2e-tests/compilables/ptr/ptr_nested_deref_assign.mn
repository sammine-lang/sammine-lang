# RUN: %sammine --file %full %O && %T/%base.exe | %check %full
# CHECK:      42

import std;

let main() -> i32 {
  let x: 'ptr<i32> = alloc<i32>(1);
  let pp: 'ptr<'ptr<i32>> = alloc<'ptr<i32>>(1);
  *x = 0;
  *pp = x;
  **pp = 42;
  std::printf("%d\n", **pp);
  free(*pp);
  free(pp);
  return 0;
}
