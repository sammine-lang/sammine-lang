// RUN: ! %sammine --file %full %O --diagnostics 2>&1 | %check %full
// CHECK:          |ptr_type_mismatch.mn:5:21
// CHECK-NEXT:    3|let main() -> i32 {
// CHECK-NEXT:    4|  let x : i32 = 0;
// CHECK-NEXT:    5|  let p : ptr<i64> = &x;
// CHECK-NEXT:     |                     ─┬
// CHECK-NEXT:     |                      ╰─ Type mismatch: expression has type ptr<i32>, but variable declared as ptr<i64>
// CHECK-NEXT:    6|  return 0;
// CHECK-NEXT:    7|}
// CHECK:      # Did something seems wrong? Report it via [https://codeberg.org/badumbatish/sammine-lang/issues]
// CHECK-NEXT: # Give us a screenshot of the error as well as your contextual source code
// CHECK-NEXT: --------------------------------------------------------------------------
let main() -> i32 {
  let x : i32 = 0;
  let p : ptr<i64> = &x;
  return 0;
}
