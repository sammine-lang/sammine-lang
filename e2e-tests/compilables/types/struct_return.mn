# RUN: %sammine --file %full %O && %T/%base.exe | %check %full
# CHECK:      a = 3, b = 7

import std;

struct Pair { a: i32, b: i32, };

let make_pair(x: i32, y: i32) -> Pair {
  return Pair { a: x, b: y };
}

let main() -> i32 {
  let p : Pair = make_pair(3, 7);
  std::printf("a = %d, b = %d\n", p.a, p.b);
  return 0;
}
