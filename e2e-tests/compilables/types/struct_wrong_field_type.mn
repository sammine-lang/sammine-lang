// RUN: ! %sammine --file %full %O --diagnostics 2>&1 | %check %full
// CHECK:          |struct_wrong_field_type.mn:16:25
// CHECK-NEXT:   14|
// CHECK-NEXT:   15|let main() -> i32 {
// CHECK-NEXT:   16|  let b : Bar = Bar { x: 3.14 };
// CHECK-NEXT:     |                         ───┬
// CHECK-NEXT:     |                            ╰─ Field 'x': expected type i32, got float literal
// CHECK-NEXT:   17|  return 0;
// CHECK-NEXT:   18|}
// CHECK:      # Did something seems wrong? Report it via [https://codeberg.org/badumbatish/sammine-lang/issues]
// CHECK-NEXT: # Give us a screenshot of the error as well as your contextual source code
// CHECK-NEXT: --------------------------------------------------------------------------
struct Bar { x: i32, };

let main() -> i32 {
  let b : Bar = Bar { x: 3.14 };
  return 0;
}
