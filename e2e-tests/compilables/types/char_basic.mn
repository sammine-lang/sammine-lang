# RUN: %sammine --file %full %O && %T/%base.exe | %check %full
# CHECK:      A
# CHECK-NEXT: z
# CHECK-NEXT: 10

import std;

let main() -> i32 {
  let c1 : char = 'A';
  let c2 : char = 'z';
  let newline : char = '\n';
  std::printf("%c\n", c1);
  std::printf("%c\n", c2);
  std::printf("%d\n", newline);
  return 0;
}
