# RUN: %sammine --file %full %O && %T/%base.exe | %check %full
# CHECK:      10 20 30

import std;
import vec;

let main() -> i32 {
  let v0 = vec::new<i32>(4);
  let v1 = vec::push<i32>(v0, 10);
  let v2 = vec::push<i32>(v1, 20);
  let v3 = vec::push<i32>(v2, 30);
  std::printf("%d %d %d", v3.data[0], v3.data[1], v3.data[2]);
  vec::delete<i32>(v3);
  return 0;
}
