typeclass Sized<T> {
  sizeof() -> i64;
}

instance Sized<i32> {
  let sizeof() -> i64 { 4i64 }
}

instance Sized<i64> {
  let sizeof() -> i64 { 8i64 }
}

instance Sized<f64> {
  let sizeof() -> i64 { 8i64 }
}

instance Sized<bool> {
  let sizeof() -> i64 { 1i64 }
}

typeclass Add<T> {
  add(a: T, b: T) -> T;
}

typeclass Sub<T> {
  sub(a: T, b: T) -> T;
}

typeclass Mul<T> {
  mul(a: T, b: T) -> T;
}

typeclass Div<T> {
  div(a: T, b: T) -> T;
}

typeclass Mod<T> {
  mod(a: T, b: T) -> T;
}
